.login-page {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background-color: #1a1a1a;
}

.camera {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.title-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.8);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

.scan-area {
  width: 400rpx;
  height: 400rpx;
  border: 4rpx solid rgba(0, 210, 255, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 40rpx;
}

.scan-line {
  position: absolute;
  top: 0;
  left: 50%;
  width: 80%;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #00d2ff, transparent);
  transform: translateX(-50%);
  animation: scanMove 2s ease-in-out infinite;
}

@keyframes scanMove {
  0%, 100% { top: 10%; }
  50% { top: 90%; }
}

.scan-text {
  font-size: 28rpx;
  color: #00d2ff;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.8);
}

.glass-panel {
  background: rgba(0, 0, 0, 0.6);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  padding: 48rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.welcome-panel {
  text-align: center;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.welcome-level {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 40rpx;
}

.enter-btn {
  margin-top: 20rpx;
}

.possible-panel {
  text-align: center;
}

.possible-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.possible-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 30rpx;
}

.possible-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.possible-actions .primary-btn,
.possible-actions .secondary-btn {
  flex: 1;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.register-panel {
  text-align: center;
}

.register-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.register-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 30rpx;
}

.name-input {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.level-picker {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 30rpx;
  text-align: left;
}

.bottom-actions {
  margin-top: 20rpx;
}

.bottom-actions .secondary-btn {
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}