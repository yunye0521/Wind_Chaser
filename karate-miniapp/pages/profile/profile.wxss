.profile-page {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

.glass-panel {
  background: rgba(0, 0, 0, 0.4);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  padding: 36rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
}

.profile-title {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
}

.profile-level {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  text-align: center;
  padding: 24rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #00d2ff;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-top: 4rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.history-list {
  height: 400rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.06);
}

.history-info {
  display: flex;
  flex-direction: column;
}

.history-level {
  font-size: 28rpx;
}

.history-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.history-stats {
  text-align: right;
}

.history-rate {
  font-size: 32rpx;
  font-weight: bold;
  color: #00ff88;
  display: block;
}

.history-detail {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
}

.bottom-actions {
  padding-bottom: 40rpx;
}